{
  "name": "mage-knight",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "workspaces": ["packages/*"],
  "scripts": {
    "viewer": "packages/python-sdk/scripts/run-viewer",
    "tensorboard": "packages/python-sdk/scripts/run-tensorboard",
    "import-tb": "packages/python-sdk/scripts/run-import-tb",
    "train-rl": "packages/python-sdk/scripts/run-train-rl",
    "build": "bun run --filter '*' build",
    "test": "cd packages/engine-rs && cargo test --workspace --exclude mk-python",
    "lint": "oxlint -c .oxlintrc.json --deny-warnings packages/*/src",
    "clean": "rm -rf node_modules packages/*/node_modules packages/*/dist bun.lockb",
    "dev:client": "bun run --filter @mage-knight/client dev",
    "dev:server": "cargo run -p mk-server --manifest-path packages/engine-rs/Cargo.toml",
    "dev": "bun run --parallel dev:server dev:client",
    "cli": "cargo run --release --bin mk-cli --manifest-path packages/engine-rs/Cargo.toml",
    "mage-dev": "bun packages/mage-dev/dist/cli.js"
  },
  "devDependencies": {
    "bun-plugin-isolated-decl": "^0.2.9",
    "bunup": "^0.16.22",
    "oxlint": "^1.43.0",
    "typescript": "^5.9.3"
  }
}
